# =====================================================================
#  Alle mod Emil — environment variables
#  Kopier denne fil til ".env" og udfyld dine egne værdier.
#  ".env" er allerede i .gitignore, så den bliver ALDRIG committet.
# =====================================================================

# --- ngrok (kun nødvendig til START-WITH-NGROK.bat) ---
# Lav en gratis konto på https://ngrok.com og hent dit token her:
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=din_ngrok_token_her

# --- Server (alle valgfri — har sane defaults) ---
# Hvilken port serveren lytter på (default 3333)
# PORT=3333

# Vært-PIN (default 1234) — vælg gerne en bedre én til festen
# HOST_PIN=4711

# Emils PIN (default 0000) — vælg en hemmelig én
# EMIL_PIN=2604

# Public URL — sæt KUN hvis du selv vil overskrive (fx hvis du
# bruger en custom domæne via Cloudflare Tunnel). ngrok-scriptet
# sætter den automatisk når den kører.
# PUBLIC_BASE_URL=https://din-custom.example.com
